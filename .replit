modules = ["bash", "nodejs-20", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["just", "rsync", "jdk21", "maven", "mariadb"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Extract Assets"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "just start-all"
waitForPort = 5000

[[workflows.workflow]]
name = "Extract Assets"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "just extract-nitro-assets"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3000
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8099
externalPort = 8099

[deployment]
deploymentTarget = "static"
build = ["bash", "-c", "cd nitro/nitro-react && npm run build"]
publicDir = "nitro/nitro-react/dist"
